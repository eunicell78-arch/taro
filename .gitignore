# Card images are committed to the repo under assets/rws/ so they are
# available on Streamlit Cloud deployments.  Only exclude images that land
# outside that directory (e.g. ad-hoc test downloads).
# assets/rws/*.jpg  ← intentionally NOT ignored
# assets/rws/*.png  ← intentionally NOT ignored
# assets/rws/*.webp ← intentionally NOT ignored

# Python
__pycache__/
*.py[cod]
*.pyo
.env
.venv/
venv/
env/

# Streamlit
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db
